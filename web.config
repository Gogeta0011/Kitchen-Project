<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 
    ═════════════════════════════════════════════════════════════════════════
    The Kitchen Platform — Web Configuration
    
    This file configures the application for deployment on IIS or Azure.
    Update connection strings, environment variables, and settings here.
    ═════════════════════════════════════════════════════════════════════════
  -->

  <!-- 
    DATABASE CONNECTION STRINGS
    ──────────────────────────────────────────────────────────────────────
    The Kitchen Platform uses SQLite by default (local file storage).
    For production, you can migrate to PostgreSQL or MySQL.
  -->
  <connectionStrings>
    <!-- SQLite (Default - included in project) -->
    <add name="KitchenDatabase" 
         connectionString="./backend/prisma/dev.db" 
         providerName="SQLite" />

    <!-- PostgreSQL (When scaling) - Uncomment to use -->
    <!-- 
    <add name="KitchenDatabase" 
         connectionString="Server=your-postgres-server.postgres.database.azure.com;Port=5432;Database=kitchen_db;User Id=your-username;Password=your-password;SslMode=Require;" 
         providerName="PostgreSQL" />
    -->

    <!-- MySQL (Alternative) - Uncomment to use -->
    <!-- 
    <add name="KitchenDatabase" 
         connectionString="Server=your-mysql-server.mysql.database.azure.com;Database=kitchen_db;Uid=your-username;Pwd=your-password;SslMode=Required;" 
         providerName="MySQL" />
    -->
  </connectionStrings>

  <!-- 
    ENVIRONMENT VARIABLES & APPLICATION SETTINGS
    ──────────────────────────────────────────────────────────────────────
    These are loaded by the backend on startup.
    Set values here or in .env file (environment file takes priority).
  -->
  <appSettings>
    <!-- Server Configuration -->
    <add key="NODE_ENV" value="production" />
    <add key="PORT" value="4000" />
    <add key="HOST" value="0.0.0.0" />

    <!-- Database Configuration -->
    <add key="DB_PATH" value="./backend/prisma/dev.db" />
    <add key="DB_TYPE" value="sqlite" />

    <!-- Security & Authentication -->
    <add key="JWT_SECRET" value="CHANGE-THIS-IN-PRODUCTION-GENERATE-RANDOM-STRING" />
    <add key="JWT_EXPIRY" value="7d" />

    <!-- Image Uploads (Cloudinary) -->
    <add key="CLOUDINARY_CLOUD_NAME" value="" />
    <add key="CLOUDINARY_API_KEY" value="" />
    <add key="CLOUDINARY_API_SECRET" value="" />

    <!-- Frontend URL (for CORS) -->
    <add key="VITE_API_BASE_URL" value="http://localhost:4000" />
    <add key="FRONTEND_URL" value="http://localhost:3000" />

    <!-- Backup Configuration -->
    <add key="BACKUP_ENABLED" value="true" />
    <add key="BACKUP_DIR" value="./backend/backups" />
    <add key="BACKUP_MAX_FILES" value="10" />

    <!-- Rate Limiting -->
    <add key="RATE_LIMIT_WINDOW" value="60000" />
    <add key="RATE_LIMIT_MAX" value="200" />
    <add key="AUTH_RATE_LIMIT" value="10" />

    <!-- Logging -->
    <add key="LOG_LEVEL" value="info" />
    <add key="LOG_SQL" value="false" />
    <add key="LOG_REQUESTS" value="false" />

    <!-- Feature Flags -->
    <add key="FEATURE_NOTIFICATIONS" value="true" />
    <add key="FEATURE_IMAGE_UPLOADS" value="true" />
    <add key="FEATURE_ADMIN_PANEL" value="true" />
    <add key="FEATURE_DATA_EXPORT" value="true" />
  </appSettings>

  <!-- 
    SYSTEM WEB SERVER CONFIGURATION (IIS)
    ──────────────────────────────────────────────────────────────────────
    Configure IIS settings for serving the React frontend and Node.js backend.
  -->
  <system.webServer>
    
    <!-- 
      STATIC CONTENT & MIME TYPES
      Ensure modern file types are served with correct MIME types.
    -->
    <staticContent>
      <!-- JSON Files -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      
      <!-- JavaScript -->
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
      
      <!-- CSS -->
      <remove fileExtension=".css" />
      <mimeMap fileExtension=".css" mimeType="text/css" />
      
      <!-- Font Files -->
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".ttf" />
      <mimeMap fileExtension=".ttf" mimeType="font/ttf" />
      
      <!-- WebP Images -->
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>

    <!-- 
      URL REWRITE RULES (SPA Routing)
      Ensures that React Router URLs work correctly.
      All requests should go to index.html, letting React handle routing.
    -->
    <rewrite>
      <rules>
        <!-- Exclude API calls from rewrite -->
        <rule name="API Requests" stopProcessing="true">
          <match url="^api/" />
          <action type="None" />
        </rule>

        <!-- Exclude real files and folders -->
        <rule name="React SPA Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- 
      SECURITY HEADERS
      Add important security headers to all responses.
    -->
    <httpProtocol>
      <customHeaders>
        <!-- Prevent clickjacking attacks -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        
        <!-- Prevent MIME sniffing -->
        <add name="X-Content-Type-Options" value="nosniff" />
        
        <!-- Enable XSS protection -->
        <add name="X-XSS-Protection" value="1; mode=block" />
        
        <!-- Referrer Policy -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        
        <!-- Feature Policy / Permissions Policy -->
        <add name="Permissions-Policy" value="camera=(), microphone=(), payment=()" />
      </customHeaders>
    </httpProtocol>

    <!-- 
      COMPRESSION
      Enable gzip compression for better performance.
    -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- 
      CORS & ORIGIN CONFIGURATION
      Enable Cross-Origin Resource Sharing for API calls.
    -->
    <cors enabled="true">
      <add origin="http://localhost:3000" allowed="true" />
      <add origin="http://localhost:4000" allowed="true" />
      <!-- Add your production domain when deploying -->
      <!-- <add origin="https://yourdomain.com" allowed="true" /> -->
    </cors>

    <!-- 
      ERROR HANDLING
      Custom error pages for better user experience.
    -->
    <httpErrors>
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" prefixLanguageFilePath="" path="/index.html" responseMode="ExecuteURL" />
    </httpErrors>

  </system.webServer>

  <!-- 
    RUNTIME & PROCESS MODEL
    ──────────────────────────────────────────────────────────────────────
    Configuration for running Node.js on IIS (via iisnode).
  -->
  <iisnode>
    <!-- Node.js executable -->
    <add name="iisnode" nodeProcessCommandLine="&quot;%ProgramFiles%\nodejs\node.exe&quot;" />
    
    <!-- Logging -->
    <logging enabled="true" logDirectory="iisnode" />
    
    <!-- Debugging (disable in production) -->
    <debugger enabled="false" />
  </iisnode>

</configuration>
